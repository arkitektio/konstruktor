{
  "identifier": "migrated",
  "description": "permissions that were migrated from v1",
  "local": true,
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "fs:allow-copy-file",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-exists",
    {
      "identifier": "fs:scope",
      "allow": [
        "$APP/**/*",
        "$APPDATA/**/*",
        "$APPLOCALDATA/**/*",
        "$HOME/**/*",
        "$DATA/**/*",
        "$XDG_CONFIG_HOME/**/*",
        "$TMP/**/*",
        "$TEMP/**/*",
        "$TMPDIR/**/*"
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "args": true,
          "cmd": "docker",
          "name": "/usr/local/bin/docker",
          "sidecar": false
        },
        {
          "args": true,
          "cmd": "docker",
          "name": "docker",
          "sidecar": false
        },
        {
          "args": true,
          "cmd": "id",
          "name": "id",
          "sidecar": false
        }
      ]
    },
    "shell:allow-open",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "dialog:allow-confirm",
    "os:allow-platform",
    "os:allow-version",
    "os:allow-os-type",
    "os:allow-family",
    "os:allow-arch",
    "os:allow-exe-extension",
    "os:allow-locale",
    "os:allow-hostname",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text",
    "fs:default",
    "dialog:default",
    "shell:default",
    "os:default",
    "clipboard-manager:default",
    "http:default"
  ]
}